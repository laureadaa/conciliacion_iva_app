# =========================================
# Freelance Suite - Environment Variables
# =========================================

# --- Server / Auth ---
# In production set this to a long random string. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database ---
DATABASE_URL=./data/app.db

# --- Client (dev only) ---
VITE_API_URL=http://localhost:4000/api

# --- Production deploy (used by docker-compose + Caddy) ---
# Set this to your public domain to enable automatic HTTPS.
# Leave as "localhost" if you only want to run locally with Docker.
DOMAIN=localhost
LETSENCRYPT_EMAIL=
