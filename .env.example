# =========================================
# Freelance AI Suite - Environment Variables
# =========================================
# La app NO usa APIs externas. Todas las generaciones (propuestas,
# emails, perfiles, justificaciones) se hacen con plantillas locales.

# --- Server ---
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Database ---
DATABASE_URL=./data/app.db

# --- Client ---
VITE_API_URL=http://localhost:4000/api
